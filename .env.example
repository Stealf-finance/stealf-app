# Stealf-app environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Variable name convention: `EXPO_PUBLIC_*` is bundled into the JS payload
# at build time and IS NOT a secret. It's just a runtime config knob.
# Truly secret values (server JWT signing keys, etc.) never live here.

# --- Required (core) — validated at boot in services/env.ts ---

EXPO_PUBLIC_API_URL=https://api.stealf.xyz
EXPO_PUBLIC_SOLANA_RPC_URL=
EXPO_PUBLIC_SOLANA_WSS_URL=
EXPO_PUBLIC_ORGANIZATION_ID=
EXPO_PUBLIC_AUTH_PROXY_CONFIG_ID=

# --- Feature-gated (validated when the slice is enabled) ---

# Slice 5 (Stealth / Umbra)
EXPO_PUBLIC_UMBRA_RELAYER_URL=

EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
EXPO_PUBLIC_DEV_BYPASS_AUTH=false

SENTRY_DISABLE_AUTO_UPLOAD=true
